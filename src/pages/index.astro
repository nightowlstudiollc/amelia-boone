---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <!-- Hero + featured posts share one photo background -->
    <section id="hero" class="relative overflow-hidden">
      <!-- Photo spans the entire section, behind both hero text and featured posts -->
      <img
        src="/hero.jpg"
        alt="Amelia Boone racing through mud and obstacles"
        class="absolute inset-0 h-full w-full object-cover object-top"
        fetchpriority="high"
      />
      <div
        class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/25 to-black/75"
      >
      </div>

      <!-- Hero text -->
      <div class="relative z-10 px-6 pt-12 pb-12 sm:px-12 sm:pt-16">
        <h1 class="text-4xl leading-tight font-bold text-white sm:text-5xl">
          Amelia Boone
        </h1>
        <p
          class="mt-3 max-w-xl text-base leading-relaxed text-white/90 sm:text-lg"
        >
          Obstacle racing champion, ultrarunner, attorney, and writer. Racing
          through sport, recovery, and everything in between.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <LinkButton
            href="/posts"
            class="rounded bg-accent px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent/90"
          >
            Read the Blog
          </LinkButton>
          <a
            href="https://ameliaboone.substack.com"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded border border-white/70 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-white/10"
          >
            Subscribe on Substack
          </a>
        </div>
      </div>

      <!-- Featured posts — inside the hero so photo shows behind -->
      {
        featuredPosts.length > 0 && (
          <div
            id="featured"
            class="relative z-10 ml-6 max-w-md rounded-t-2xl border border-white/10 bg-black/20 px-4 pt-8 pb-6 text-white/90 backdrop-blur-xl sm:ml-12"
          >
            <h2 class="text-2xl font-semibold tracking-wide text-white">
              Recent Writing
            </h2>
            <ul>
              {featuredPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
            <div class="mt-6 text-center">
              <LinkButton href="/posts/">
                All Posts
                <IconArrowRight class="inline-block rtl:-rotate-180" />
              </LinkButton>
            </div>
          </div>
        )
      }
    </section>

    <!-- Archive callout — below the hero, normal page background -->
    <section class="app-layout py-12">
      <div
        class="rounded-lg border border-border bg-muted/30 px-6 py-8 text-center"
      >
        <h2 class="text-xl font-semibold">From the Archive</h2>
        <p class="mt-2 text-sm leading-relaxed opacity-80">
          Race reports, injury dispatches, and essays from a decade of competing
          at the edges of endurance.
        </p>
        <div class="mt-5 flex flex-wrap justify-center gap-3">
          <LinkButton href="/posts/">
            Browse All Posts
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>
          <LinkButton href="/archives/">
            Browse by Year
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>

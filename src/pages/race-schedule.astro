---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
---

<Layout title="Race Schedule & Results | Amelia Boone">
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout py-10">
    <h1 class="mb-2 text-3xl font-bold">Race Schedule &amp; Results</h1>
    <p class="mb-8 text-sm opacity-60">
      I'm commitment-phobic, so this will change. A bunch.
    </p>

    <div class="app-prose max-w-app">
      <h2>2018</h2>
      <ul>
        <li>Sean O'Brien 100k (02.03.18) — 5th place female</li>
        <li>
          Mt Umunhum 34k (02.24.18) — 1st female; 1st place overall (course
          record)
        </li>
        <li>
          The Barkley Marathons (03.24.18) — DNF (Loop 1 completed, timed out
          completing Loop 2)
        </li>
        <li>Montana Spartan Beast (05.05.18) — 4th place female</li>
        <li>Monterey Super Spartan (06.09.18) — 1st place female</li>
        <li>Broken Arrow Skyrace 26k (06.17.18) — 4th place female</li>
        <li>Palmerton Spartan Super (07.14.18) — 2nd place female</li>
        <li>Portland Spartan Sprint (08.11.18) — 2nd place female</li>
      </ul>

      <h2>2017</h2>
      <ul>
        <li>
          Rodeo Beach Half-Marathon (04.29.17) — 1st place female; 2nd overall
        </li>
        <li>Austin Super Spartan (05.20.17) — 2nd place female</li>
        <li>Monterey Super Spartan (06.02.17) — 6th place female</li>
        <li>Palmerton Super Spartan (07.08.17) — 4th place female</li>
        <li>Utah Super Spartan (08.05.17) — 1st place female</li>
        <li>Spartan Race World Championships (09.30.17) — 11th place female</li>
        <li>
          Saratoga Trail Half-Marathon (11.04.17) — 1st place female; 2nd
          overall
        </li>
      </ul>

      <h2>2016</h2>
      <ul>
        <li>Sean O'Brien 100k (02.06.16) — 2nd female; 4th overall</li>
        <li>
          Woodside Crossover 50k (04.09.16) — 1st female; 1st overall (female
          course record)
        </li>
        <li>April 23rd — 1st place at fracturing my femur</li>
        <li>Western States 100 (06.25.16) — DNS</li>
      </ul>
      <p>
        Out the rest of 2016 with rehab and recovery from dual femur and sacral
        fractures —
        <a href="/posts">read about the journey on the blog</a>.
